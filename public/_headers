# Cloudflare Workers Static Assets — HTTP response headers

# ── Security headers (applied to every response) ─────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

# ── Service Worker — NUNCA cachear, el browser siempre debe pedir la última versión
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8
  Service-Worker-Allowed: /

# ── PWA Manifest ──────────────────────────────────────────────────────────────
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/manifest+json; charset=utf-8

# ── HTML — nunca cachear para que los usuarios siempre reciban el último deploy
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate

# ── Workbox precache manifest (generado por vite-plugin-pwa) ─────────────────
/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8

# ── Versioned JS/CSS — Vite añade hash al nombre → se puede cachear forever ──
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# ── iOS PWA icon — no-cache CRÍTICO: evita que iOS cachee una respuesta mala
# (ej: cuando el archivo no existía aún y CF devolvía index.html como SPA fallback)
# Esta regla va ANTES de /*.png para que tenga precedencia
/apple-touch-icon.png
  Cache-Control: no-cache, no-store, must-revalidate

# ── Static assets ─────────────────────────────────────────────────────────────
/assets/*
  Cache-Control: public, max-age=86400

/*.svg
  Cache-Control: public, max-age=86400

/*.png
  Cache-Control: public, max-age=86400

/*.ico
  Cache-Control: public, max-age=86400
